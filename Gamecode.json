  16  function shuffle(a){for(let i=a.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[a[i],a[j]]=[a[j],a[i]]}return a}
  17  
  18  function pickCards(){
  19    const shuffled = shuffle([...ALL_CARDS]);
  20    return shuffled.slice(0, 25);
  21  }
  22  
  23  function assignTeams(){
  24    // 9 blue, 8 red, 7 neutral, 1 assassin
  25    const types = [];
  26    for(let i=0;i<9;i++) types.push('blue');
  27    for(let i=0;i<8;i++) types.push('red');
  28    for(let i=0;i<7;i++) types.push('neutral');
  29    types.push('assassin');
  30    return shuffle(types);
  31  }
