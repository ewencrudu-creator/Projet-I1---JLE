  33  // ── PERIOD COLORS ──
  34  const periodColors = {
  35    'Early Open Sharing':'#10b981',
  36    'Commercialization':'#f59e0b',
  37    'Free Software Movement':'#8b5cf6',
  38    'Rise of Open Source':'#3b82f6',
  39    'Mainstream Adoption':'#ec4899',
  40    'Modern Open Source':'#06b6d4'
  41  };
  42  
  43  const familyIcons = {
  44    'Technological':'⚙️','Infrastructure':'🏗️','Organizational':'🏛️',
  45    'Legal':'⚖️','Licensing':'📜','Cultural':'🌍','Networking':'🌐'
