<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CodeNoms — Communautés en ligne</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{
  --bg:#07090f;--surface:#0f1520;--surface2:#151e2e;
  --blue:#4f8ef7;--blue-dim:#172040;--blue-glow:rgba(79,142,247,.2);
  --red:#f75f4f;--red-dim:#401717;--red-glow:rgba(247,95,79,.2);
  --neutral:#64748b;--neutral-dim:#1e2535;
  --assassin:#000;--assassin-border:#dc2626;
  --text:#dde4f0;--text-dim:#7a8aaa;--text-dark:#3a4a66;
  --gold:#f5c842;--green:#2dd4a0;
  --font-mono:'Space Mono',monospace;--font-sans:'Syne',sans-serif;
}
html,body{height:100%;font-family:var(--font-sans);background:var(--bg);color:var(--text);overflow-x:hidden}
body{display:flex;flex-direction:column;min-height:100vh}

/* ── SPLASH ── */
.splash{position:fixed;inset:0;z-index:1000;background:var(--bg);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:24px;transition:opacity .6s,visibility .6s;padding:20px}
.splash.hidden{opacity:0;visibility:hidden;pointer-events:none}
.splash-title{font-size:clamp(2.8rem,8vw,5.5rem);font-weight:800;letter-spacing:-3px;line-height:1}
.splash-title .t1{color:var(--blue)}
.splash-title .t2{color:var(--text)}
.splash-title .t3{color:var(--red)}
.splash p{color:var(--text-dim);font-size:1rem;max-width:500px;text-align:center;line-height:1.7}
.rules-box{text-align:left;background:var(--surface);border:1px solid rgba(255,255,255,.07);border-radius:16px;padding:22px 26px;max-width:560px;width:100%;font-size:.88rem;line-height:1.8;color:var(--text-dim)}
.rules-box strong{color:var(--text)}
.dot{display:inline-block;width:10px;height:10px;border-radius:50%;margin-right:5px;vertical-align:-1px}
.dot.b{background:var(--blue)}.dot.r{background:var(--red)}.dot.n{background:var(--neutral)}.dot.a{background:#1a0000;border:2px solid var(--assassin-border)}
.btn{font-family:var(--font-sans);font-weight:700;font-size:.95rem;border:none;border-radius:10px;padding:13px 32px;cursor:pointer;transition:all .2s;letter-spacing:.3px}
.btn-start{background:linear-gradient(135deg,var(--blue),#7c6ef7);color:#fff;box-shadow:0 4px 28px rgba(79,142,247,.3)}
.btn-start:hover{transform:translateY(-2px);box-shadow:0 8px 36px rgba(79,142,247,.45)}
.btn-sm{padding:7px 16px;font-size:.8rem;border-radius:8px}
.btn-outline{background:transparent;border:1.5px solid rgba(255,255,255,.12);color:var(--text-dim)}
.btn-outline:hover{border-color:var(--blue);color:var(--blue)}

/* ── TOP BAR ── */
.topbar{display:flex;align-items:center;justify-content:space-between;padding:10px 18px;background:var(--surface);border-bottom:1px solid rgba(255,255,255,.05);flex-wrap:wrap;gap:8px}
.logo{font-family:var(--font-mono);font-weight:700;font-size:1rem;letter-spacing:-1px}
.logo .l1{color:var(--blue)}.logo .l2{color:var(--text)}.logo .l3{color:var(--red)}
.score-area{display:flex;gap:12px;align-items:center;flex-wrap:wrap}
.score-pill{display:flex;align-items:center;gap:6px;padding:5px 14px;border-radius:20px;font-weight:700;font-size:.88rem}
.score-pill.blue{background:var(--blue-dim);color:var(--blue)}.score-pill.red{background:var(--red-dim);color:var(--red)}
.turn-badge{padding:5px 14px;border-radius:20px;font-weight:700;font-size:.8rem;animation:pulse 2s infinite}
.turn-badge.blue{background:var(--blue-dim);color:var(--blue);border:1px solid var(--blue)}.turn-badge.red{background:var(--red-dim);color:var(--red);border:1px solid var(--red)}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.6}}

/* ── SPY BAR ── */
.spy-bar{display:flex;align-items:center;justify-content:center;gap:10px;padding:9px 18px;background:rgba(245,200,66,.05);border-bottom:1px solid rgba(245,200,66,.1)}
.spy-bar label{font-size:.82rem;color:var(--gold);font-weight:700;letter-spacing:.3px}
.toggle{position:relative;width:42px;height:23px;cursor:pointer}
.toggle input{display:none}
.toggle .slider{position:absolute;inset:0;background:var(--neutral-dim);border-radius:12px;transition:.3s}
.toggle .slider::before{content:'';position:absolute;width:17px;height:17px;left:3px;top:3px;background:var(--text-dim);border-radius:50%;transition:.3s}
.toggle input:checked+.slider{background:var(--gold)}.toggle input:checked+.slider::before{transform:translateX(19px);background:#fff}

/* ── HINT AREA ── */
.hint-area{display:flex;align-items:center;justify-content:center;gap:10px;padding:9px 18px;background:var(--surface2);border-bottom:1px solid rgba(255,255,255,.04);flex-wrap:wrap}
.hint-area input{font-family:var(--font-mono);background:var(--surface);border:1.5px solid rgba(255,255,255,.09);color:var(--text);padding:7px 12px;border-radius:8px;font-size:.88rem;width:170px;text-align:center}
.hint-area input::placeholder{color:var(--text-dark)}
.hint-area input[type=number]{width:56px}
.hint-display{font-family:var(--font-mono);font-size:1rem;font-weight:700;color:var(--gold);letter-spacing:1px}

/* ── GRID ── */
.grid-wrap{flex:1;display:flex;align-items:center;justify-content:center;padding:14px}
.grid{display:grid;grid-template-columns:repeat(5,1fr);gap:9px;max-width:940px;width:100%}
.card{position:relative;aspect-ratio:1.55;border-radius:11px;cursor:pointer;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:7px 5px;border:2px solid rgba(255,255,255,.07);background:var(--surface2);transition:all .22s;overflow:hidden;user-select:none}
.card:hover:not(.revealed){transform:translateY(-3px);border-color:rgba(255,255,255,.16);box-shadow:0 8px 22px rgba(0,0,0,.35)}
.card .card-name{font-weight:700;font-size:clamp(.58rem,1.35vw,.85rem);line-height:1.2;z-index:1;padding:0 2px;word-break:break-word}
.card .card-cat{font-size:.58rem;color:var(--text-dark);margin-top:3px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;z-index:1}

/* Spy mode */
.card.spy-blue{border-color:var(--blue);box-shadow:inset 0 0 18px var(--blue-glow)}
.card.spy-blue::after{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:var(--blue)}
.card.spy-red{border-color:var(--red);box-shadow:inset 0 0 18px var(--red-glow)}
.card.spy-red::after{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:var(--red)}
.card.spy-neutral{border-color:var(--neutral);opacity:.65}
.card.spy-assassin{border-color:var(--assassin-border);background:repeating-linear-gradient(45deg,var(--surface2),var(--surface2) 4px,rgba(220,38,38,.07) 4px,rgba(220,38,38,.07) 8px)}

/* Revealed */
.card.revealed{cursor:default;transform:none !important}
.card.revealed.team-blue{background:linear-gradient(135deg,var(--blue-dim),rgba(79,142,247,.12));border-color:var(--blue)}
.card.revealed.team-blue .card-name{color:var(--blue)}
.card.revealed.team-red{background:linear-gradient(135deg,var(--red-dim),rgba(247,95,79,.12));border-color:var(--red)}
.card.revealed.team-red .card-name{color:var(--red)}
.card.revealed.team-neutral{background:var(--neutral-dim);border-color:var(--neutral);opacity:.45}
.card.revealed.team-neutral .card-name{color:var(--neutral)}
.card.revealed.team-assassin{background:linear-gradient(135deg,#1a0000,#2d0000);border-color:var(--assassin-border)}
.card.revealed.team-assassin .card-name{color:var(--red);text-decoration:line-through}
.card .reveal-icon{position:absolute;top:5px;right:7px;font-size:.75rem;opacity:0;transition:opacity .3s}
.card.revealed .reveal-icon{opacity:1}

/* Tooltip */
.card .tooltip{position:absolute;bottom:105%;left:50%;transform:translateX(-50%);background:#1a2540;border:1px solid rgba(255,255,255,.1);border-radius:10px;padding:9px 13px;width:200px;font-size:.73rem;line-height:1.5;color:var(--text-dim);pointer-events:none;opacity:0;transition:opacity .2s;z-index:50;box-shadow:0 8px 22px rgba(0,0,0,.5)}
.card:hover .tooltip{opacity:1}
.tooltip strong{color:var(--text);display:block;margin-bottom:2px}

/* Modal */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.75);z-index:500;display:flex;align-items:center;justify-content:center;opacity:0;visibility:hidden;transition:all .3s}
.modal-overlay.show{opacity:1;visibility:visible}
.modal{background:var(--surface);border:1px solid rgba(255,255,255,.08);border-radius:18px;padding:34px;text-align:center;max-width:400px;width:90%}
.modal h2{font-size:1.7rem;margin-bottom:8px}
.modal p{color:var(--text-dim);margin-bottom:20px;line-height:1.6}
.winner-blue{color:var(--blue)}.winner-red{color:var(--red)}

/* Log */
.log-bar{padding:7px 18px;background:var(--surface);border-top:1px solid rgba(255,255,255,.05);font-size:.75rem;color:var(--text-dark);font-family:var(--font-mono);overflow-x:auto;white-space:nowrap;display:flex;gap:14px}
.log-entry{opacity:.65}.log-entry:last-child{opacity:1;color:var(--text-dim)}

@media(max-width:680px){
  .grid{gap:5px}
  .card{padding:4px 2px;border-radius:8px;aspect-ratio:1.2}
  .card .card-name{font-size:.5rem}
  .card .card-cat{display:none}
  .card .tooltip{display:none}
  .hint-area{gap:6px}
}
</style>
</head>
<body>

<!-- SPLASH -->
<div class="splash" id="splash">
  <div class="splash-title"><span class="t1">Code</span><span class="t2">Noms</span></div>
  <p>Un jeu <strong>Codenames</strong> sur les <strong>communautés en ligne</strong> et la <strong>production collaborative</strong></p>
  <div class="rules-box">
    <strong>Règles :</strong><br><br>
    Deux équipes s'affrontent : <span class="dot b"></span><strong>Bleu</strong> et <span class="dot r"></span><strong>Rouge</strong>.<br><br>
    Le <strong>Maître-Espion</strong> active son mode, voit les couleurs secrètes, puis donne un <strong>indice</strong> (un mot + un chiffre) pour faire deviner ses cartes.<br><br>
    <span class="dot b"></span> 9 cartes bleues &nbsp;·&nbsp; <span class="dot r"></span> 8 cartes rouges &nbsp;·&nbsp; <span class="dot n"></span> 7 neutres &nbsp;·&nbsp; <span class="dot a"></span> 1 assassin<br><br>
    Révéler l'<strong>Assassin</strong> = défaite immédiate ! Survolez les cartes pour voir leur description.
  </div>
  <button class="btn btn-start" onclick="startGame()">🚀 Commencer la partie</button>
</div>

<!-- GAME -->
<div class="topbar">
  <div class="logo"><span class="l1">&lt;</span><span class="l2">CodeNoms</span><span class="l3">/&gt;</span></div>
  <div class="score-area">
    <div class="score-pill blue" id="scoreBlue">🔵 Bleu : 9</div>
    <div class="turn-badge blue" id="turnBadge">Tour : Bleu</div>
    <div class="score-pill red" id="scoreRed">🔴 Rouge : 8</div>
  </div>
  <div style="display:flex;gap:7px">
    <button class="btn btn-sm btn-outline" onclick="passTurn()">Passer</button>
    <button class="btn btn-sm btn-outline" onclick="newGame()">Nouvelle partie</button>
  </div>
</div>

<div class="spy-bar">
  <label>🕵️ Mode Maître-Espion</label>
  <label class="toggle"><input type="checkbox" id="spyToggle" onchange="toggleSpy()"><span class="slider"></span></label>
</div>

<div class="hint-area" id="hintArea">
  <input type="text" id="hintWord" placeholder="Votre indice…">
  <input type="number" id="hintNum" min="0" max="9" value="2">
  <button class="btn btn-sm btn-start" onclick="giveHint()">Donner l'indice</button>
  <div class="hint-display" id="hintDisplay"></div>
</div>

<div class="grid-wrap">
  <div class="grid" id="grid"></div>
</div>

<div class="log-bar" id="logBar"><span class="log-entry">Partie prête…</span></div>

<div class="modal-overlay" id="modal">
  <div class="modal">
    <h2 id="modalTitle">Victoire !</h2>
    <p id="modalMsg"></p>
    <button class="btn btn-start" onclick="newGame();document.getElementById('modal').classList.remove('show')">🔄 Rejouer</button>
  </div>
</div>

<script>
// ── CARTES ──
const ALL_CARDS = [
  // Plateformes
  {name:"Wikipedia",     cat:"Plateforme", desc:"Encyclopédie libre écrite collaborativement"},
  {name:"GitHub",        cat:"Plateforme", desc:"Hébergement de code et collaboration open source"},
  {name:"Linux",         cat:"Plateforme", desc:"Système d'exploitation libre et communautaire"},
  {name:"Firefox",       cat:"Plateforme", desc:"Navigateur web libre développé par Mozilla"},
  {name:"Reddit",        cat:"Plateforme", desc:"Forum de discussion organisé en sous-communautés"},
  {name:"Discord",       cat:"Plateforme", desc:"Application de messagerie pour communautés en ligne"},
  {name:"YouTube",       cat:"Plateforme", desc:"Plateforme de partage de vidéos en ligne"},
  {name:"Twitter/X",     cat:"Plateforme", desc:"Réseau social de microblogging"},
  {name:"Twitch",        cat:"Plateforme", desc:"Plateforme de streaming en direct"},
  {name:"Zoom",          cat:"Plateforme", desc:"Outil de visioconférence largement adopté"},
  {name:"WhatsApp",      cat:"Plateforme", desc:"Messagerie instantanée mobile"},
  {name:"Telegram",      cat:"Plateforme", desc:"Messagerie chiffrée avec groupes et canaux"},
  // Rôles
  {name:"Contributeur",  cat:"Rôle", desc:"Personne qui apporte du contenu ou du code"},
  {name:"Modérateur",    cat:"Rôle", desc:"Garde la communauté saine et respectueuse"},
  {name:"Bénévole",      cat:"Rôle", desc:"Contribue sans rémunération par passion"},
  {name:"Administrateur",cat:"Rôle", desc:"Gère les accès et paramètres d'une plateforme"},
  {name:"Novice",        cat:"Rôle", desc:"Nouveau membre qui apprend les règles"},
  {name:"Mentor",        cat:"Rôle", desc:"Guide les nouveaux membres dans la communauté"},
  {name:"Troll",         cat:"Rôle", desc:"Provoque les autres membres pour créer des conflits"},
  {name:"Spammeur",      cat:"Rôle", desc:"Inonde la communauté de messages non désirés"},
  {name:"Abonné",        cat:"Rôle", desc:"Suit un créateur ou une communauté"},
  {name:"Fondateur",     cat:"Rôle", desc:"Créateur original d'une communauté ou d'un projet"},
  {name:"Créateur",      cat:"Rôle", desc:"Produit du contenu original pour sa communauté"},
  {name:"Lecteur",       cat:"Rôle", desc:"Consulte le contenu sans forcément contribuer"},
  {name:"Visiteur",      cat:"Rôle", desc:"Passe sur la plateforme sans s'inscrire"},
  {name:"Expert",        cat:"Rôle", desc:"Maîtrise un domaine et partage son savoir"},
  {name:"Débutant",      cat:"Rôle", desc:"Commence à apprendre et à participer"},
  {name:"Leader",        cat:"Rôle", desc:"Inspire et guide l'orientation d'un groupe"},
  // Droits & Licences
  {name:"Copyright",     cat:"Droit", desc:"Droit exclusif de l'auteur sur son œuvre"},
  {name:"Domaine public",cat:"Droit", desc:"Œuvre librement utilisable par tous"},
  {name:"Licence",       cat:"Droit", desc:"Contrat définissant les droits d'utilisation"},
  {name:"Liberté",       cat:"Droit", desc:"Principe fondamental des logiciels libres"},
  {name:"Accès",         cat:"Droit", desc:"Possibilité de consulter une ressource"},
  // Valeurs communautaires
  {name:"Partage",       cat:"Valeur", desc:"Mettre ses ressources à disposition de tous"},
  {name:"Collaboration", cat:"Valeur", desc:"Travailler ensemble vers un objectif commun"},
  {name:"Consensus",     cat:"Valeur", desc:"Décision prise d'un commun accord"},
  {name:"Vote",          cat:"Valeur", desc:"Mécanisme de décision collective"},
  {name:"Conflit",       cat:"Valeur", desc:"Désaccord entre membres d'une communauté"},
  {name:"Gouvernance",   cat:"Valeur", desc:"Manière dont une communauté se gère"},
  {name:"Règles",        cat:"Valeur", desc:"Normes de comportement dans une communauté"},
  {name:"Charte",        cat:"Valeur", desc:"Document officiel définissant les valeurs du groupe"},
  {name:"Inclusion",     cat:"Valeur", desc:"Accueillir tous les profils sans discrimination"},
  {name:"Exclusion",     cat:"Valeur", desc:"Bannir un membre pour comportement inapproprié"},
  {name:"Réputation",    cat:"Valeur", desc:"Image construite par les actions passées"},
  {name:"Confiance",     cat:"Valeur", desc:"Base indispensable de toute communauté saine"},
  {name:"Transparence",  cat:"Valeur", desc:"Rendre les décisions et processus visibles"},
  {name:"Sécurité",      cat:"Valeur", desc:"Protection des données et des membres"},
  // Peer to peer / Technique
  {name:"Décentralisation",cat:"P2P", desc:"Répartir le pouvoir sans autorité centrale"},
  {name:"Réseau",        cat:"P2P", desc:"Ensemble de nœuds connectés entre eux"},
  {name:"Nœud",          cat:"P2P", desc:"Point de connexion dans un réseau pair à pair"},
  {name:"Pair",          cat:"P2P", desc:"Participant égal dans un réseau P2P"},
  {name:"Protocole",     cat:"P2P", desc:"Ensemble de règles pour communiquer en réseau"},
  {name:"Torrent",       cat:"P2P", desc:"Protocole de partage de fichiers décentralisé"},
  {name:"Blockchain",    cat:"P2P", desc:"Registre décentralisé infalsifiable"},
  {name:"Anonymat",      cat:"P2P", desc:"Naviguer ou contribuer sans révéler son identité"},
  // Actions
  {name:"Like",          cat:"Action", desc:"Exprimer son appréciation d'un contenu"},
  {name:"Commenter",     cat:"Action", desc:"Laisser un avis sous un contenu"},
  {name:"Publier",       cat:"Action", desc:"Mettre en ligne un contenu pour tous"},
  {name:"Signaler",      cat:"Action", desc:"Alerter les modérateurs d'un problème"},
  {name:"Bloquer",       cat:"Action", desc:"Empêcher un utilisateur de vous contacter"},
  {name:"Inviter",       cat:"Action", desc:"Faire venir quelqu'un dans une communauté"},
  {name:"Rejoindre",     cat:"Action", desc:"Devenir membre d'un groupe ou plateforme"},
  {name:"Quitter",       cat:"Action", desc:"Se retirer d'une communauté ou plateforme"},
  // Production collaborative
  {name:"Documentation", cat:"Contribution", desc:"Écrire des guides pour aider les autres"},
  {name:"Traduction",    cat:"Contribution", desc:"Rendre un contenu accessible en d'autres langues"},
  {name:"Relecture",     cat:"Contribution", desc:"Vérifier et corriger le travail d'un autre"},
  {name:"Correction",    cat:"Contribution", desc:"Réparer une erreur dans un contenu existant"},
  {name:"Amélioration",  cat:"Contribution", desc:"Enrichir un contenu déjà existant"},
  {name:"Fusion",        cat:"Contribution", desc:"Intégrer deux versions d'un même fichier"},
  {name:"Révision",      cat:"Contribution", desc:"Nouvelle version corrigée d'un contenu"},
  {name:"Qualité",       cat:"Contribution", desc:"Viser l'excellence dans ses contributions"},
  {name:"Validation",    cat:"Contribution", desc:"Approuver une contribution avant publication"},
  {name:"Archivage",     cat:"Contribution", desc:"Conserver durablement des ressources importantes"},
  // Statut & Technique
  {name:"Gratuit",       cat:"Statut", desc:"Disponible sans payer, souvent open source"},
  {name:"Ouvert",        cat:"Statut", desc:"Accessible à tous, code ou contenu libre"},
  {name:"Fermé",         cat:"Statut", desc:"Accès restreint ou code source non disponible"},
  {name:"Public",        cat:"Statut", desc:"Visible par tous sans authentification"},
  {name:"Privé",         cat:"Statut", desc:"Accessible uniquement aux membres autorisés"},
  {name:"Mot de passe",  cat:"Technique", desc:"Clé secrète pour protéger un compte"},
  {name:"Identité",      cat:"Technique", desc:"Qui vous êtes en ligne, réelle ou pseudonyme"},
  {name:"Mise à jour",   cat:"Technique", desc:"Nouvelle version améliorée d'un logiciel"},
  {name:"Téléchargement",cat:"Technique", desc:"Récupérer un fichier depuis internet"},
  {name:"Lien",          cat:"Technique", desc:"URL qui pointe vers une ressource en ligne"},
  {name:"Serveur",       cat:"Technique", desc:"Machine qui héberge des données ou services"},
  {name:"Profil",        cat:"Technique", desc:"Page présentant un utilisateur"},
  {name:"Compte",        cat:"Technique", desc:"Identifiant pour accéder à une plateforme"},
  {name:"Message",       cat:"Technique", desc:"Communication envoyée entre utilisateurs"},
  {name:"Forum",         cat:"Technique", desc:"Espace de discussion organisé par sujets"},
  {name:"Badge",         cat:"Technique", desc:"Récompense virtuelle pour les contributions"}
];

const catColors = {
  "Plateforme":"#4f8ef7","Rôle":"#a78bfa","Droit":"#f59e0b",
  "Valeur":"#2dd4a0","P2P":"#f75f4f","Action":"#ec4899",
  "Contribution":"#38bdf8","Statut":"#84cc16","Technique":"#64748b"
};
const catIcons = {
  "Plateforme":"🌐","Rôle":"👤","Droit":"⚖️","Valeur":"🤝",
  "P2P":"🔗","Action":"✨","Contribution":"✏️","Statut":"🔓","Technique":"⚙️"
};

// ── STATE ──
let board=[], turn='blue', blueLeft=9, redLeft=8;
let spyMode=false, guessesLeft=0, hintActive=false, gameOver=false, logs=[];

function shuffle(a){for(let i=a.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[a[i],a[j]]=[a[j],a[i]]}return a}

function initBoard(){
  const cards = shuffle([...ALL_CARDS]).slice(0,25);
  const types = shuffle([...'blue'.repeat ? [] : []]);
  const t=[];
  for(let i=0;i<9;i++)t.push('blue');
  for(let i=0;i<8;i++)t.push('red');
  for(let i=0;i<7;i++)t.push('neutral');
  t.push('assassin');
  shuffle(t);
  board = cards.map((c,i)=>({...c,team:t[i],revealed:false}));
  turn='blue';blueLeft=9;redLeft=8;
  spyMode=false;hintActive=false;guessesLeft=0;gameOver=false;logs=[];
  document.getElementById('spyToggle').checked=false;
  document.getElementById('hintDisplay').textContent='';
  addLog('🎮 Nouvelle partie ! Équipe Bleu commence.');
  updateUI();
}

function renderGrid(){
  const grid=document.getElementById('grid');
  grid.innerHTML='';
  board.forEach((c,i)=>{
    const div=document.createElement('div');
    div.className='card';
    if(c.revealed) div.classList.add('revealed','team-'+c.team);
    if(spyMode&&!c.revealed) div.classList.add('spy-'+c.team);
    const col=catColors[c.cat]||'#64748b';
    const icon=catIcons[c.cat]||'📦';
    div.innerHTML=`
      <div class="tooltip"><strong>${icon} ${c.name}</strong>${c.desc}<br><span style="color:${col}">▸ ${c.cat}</span></div>
      <div class="reveal-icon">${c.revealed?(c.team==='blue'?'🔵':c.team==='red'?'🔴':c.team==='assassin'?'💀':'⚪'):''}</div>
      <div class="card-name">${c.name}</div>
      <div class="card-cat" style="color:${col}">${icon} ${c.cat}</div>`;
    if(!c.revealed&&!gameOver) div.onclick=()=>revealCard(i);
    grid.appendChild(div);
  });
}

function updateUI(){
  document.getElementById('scoreBlue').textContent=`🔵 Bleu : ${blueLeft}`;
  document.getElementById('scoreRed').textContent=`🔴 Rouge : ${redLeft}`;
  const badge=document.getElementById('turnBadge');
  badge.textContent=`Tour : ${turn==='blue'?'Bleu':'Rouge'}`;
  badge.className='turn-badge '+turn;
  renderGrid();
}

function addLog(msg){
  logs.push(msg);if(logs.length>12)logs.shift();
  const bar=document.getElementById('logBar');
  bar.innerHTML=logs.map(l=>`<span class="log-entry">${l}</span>`).join('');
  bar.scrollLeft=bar.scrollWidth;
}

function revealCard(i){
  if(board[i].revealed||gameOver)return;
  if(!hintActive){addLog('⚠️ Donnez d\'abord un indice !');return;}
  board[i].revealed=true;
  const c=board[i];
  if(c.team==='assassin'){
    addLog(`💀 ${c.name} — ASSASSIN ! ${turn==='blue'?'Rouge':'Bleu'} gagne !`);
    gameOver=true;showWin(turn==='blue'?'red':'blue',true);updateUI();return;
  }
  if(c.team==='blue'){
    blueLeft--;addLog(`🔵 ${c.name} — Correct pour Bleu !`);
    if(blueLeft===0){gameOver=true;showWin('blue');updateUI();return;}
    if(turn!=='blue')guessesLeft=0;
  } else if(c.team==='red'){
    redLeft--;addLog(`🔴 ${c.name} — Correct pour Rouge !`);
    if(redLeft===0){gameOver=true;showWin('red');updateUI();return;}
    if(turn!=='red')guessesLeft=0;
  } else {
    addLog(`⚪ ${c.name} — Neutre. Fin du tour.`);guessesLeft=0;
  }
  if(c.team===turn){
    guessesLeft--;
    if(guessesLeft<=0){addLog(`↩️ Tour de ${turn==='blue'?'Rouge':'Bleu'}.`);switchTurn();}
  } else switchTurn();
  updateUI();
}

function switchTurn(){
  turn=turn==='blue'?'red':'blue';
  hintActive=false;guessesLeft=0;
  document.getElementById('hintDisplay').textContent='';
}

function passTurn(){
  if(gameOver)return;
  addLog(`⏭️ ${turn==='blue'?'Bleu':'Rouge'} passe son tour.`);
  switchTurn();updateUI();
}

function giveHint(){
  if(gameOver)return;
  const word=document.getElementById('hintWord').value.trim();
  const num=parseInt(document.getElementById('hintNum').value)||0;
  if(!word){addLog('⚠️ Entrez un mot !');return;}
  hintActive=true;guessesLeft=num+1;
  document.getElementById('hintDisplay').textContent=`🔎 "${word.toUpperCase()}" → ${num}`;
  document.getElementById('hintWord').value='';
  addLog(`💡 ${turn==='blue'?'Bleu':'Rouge'} : "${word}" pour ${num}`);
}

function toggleSpy(){spyMode=document.getElementById('spyToggle').checked;renderGrid();}

function showWin(winner,assassin=false){
  document.getElementById('modalTitle').innerHTML=`<span class="winner-${winner}">${winner==='blue'?'🔵 Bleu':'🔴 Rouge'} gagne !</span>`;
  document.getElementById('modalMsg').textContent=assassin?`L'équipe adverse a révélé l'Assassin !`:`Toutes les cartes ${winner==='blue'?'bleues':'rouges'} ont été trouvées !`;
  document.getElementById('modal').classList.add('show');
}

function startGame(){document.getElementById('splash').classList.add('hidden');initBoard();}
function newGame(){document.getElementById('modal').classList.remove('show');initBoard();}

initBoard();
</script>
</body>
</html>
