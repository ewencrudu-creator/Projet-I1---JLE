  48  // ── RENDER ──
  49  function renderGrid(){
  50    const grid = document.getElementById('grid');
  51    grid.innerHTML = '';
  52    board.forEach((c, i) => {
  53      const div = document.createElement('div');
  54      div.className = 'card';
  55      if(c.revealed) div.classList.add('revealed', 'team-' + c.team);
  56      if(spyMode && !c.revealed) div.classList.add('spy-' + c.team);
  57  
  58      const pColor = periodColors[c.period] || '#64748b';
  59      const icon = familyIcons[c.family] || '📦';
  60  
  61      div.innerHTML = `
  62        <div class="tooltip">
  63          <strong>${icon} ${c.name}</strong>
  64          ${c.description}<br>
  65          <span style="color:${pColor}">▸ ${c.period}</span>
  66          ${c.depends ? '<br>↳ Dépend de: ' + c.depends : ''}
  67        </div>
  68        <div class="reveal-icon">${c.revealed ? (c.team==='blue'?'🔵':c.team==='red'?'🔴':c.team==='assassin'?'💀':'⚪') : ''}</div>
  69        <div class="card-name">${c.name}</div>
  70        <div class="card-family">${icon} ${c.family}</div>
  71        <div class="card-period" style="color:${pColor}">${c.period}</div>
  72      `;
  73  
  74      if(!c.revealed && !gameOver) div.onclick = () => revealCard(i);
  75      grid.appendChild(div);
  76    });
  77  }
  78  
  79  function updateUI(){
  80    document.getElementById('scoreBlue').textContent = `Bleu: ${blueLeft}`;
  81    document.getElementById('scoreRed').textContent = `Rouge: ${redLeft}`;
  82    const badge = document.getElementById('turnBadge');
  83    badge.textContent = `Tour : ${turn === 'blue' ? 'Bleu' : 'Rouge'}`;
  84    badge.className = 'turn-badge ' + turn;
  85    renderGrid();
  86  }
  87  
  88  function addLog(msg){
  89    logs.push(msg);
  90    if(logs.length > 12) logs.shift();
  91    const bar = document.getElementById('logBar');
  92    bar.innerHTML = logs.map(l => `<span class="log-entry">${l}</span>`).join('');
  93    bar.scrollLeft = bar.scrollWidth;
  94  }
  95  
  96  // ── GAME LOGIC ──
  97  function revealCard(i){
  98    if(board[i].revealed || gameOver) return;
  99    if(!hintActive){addLog('⚠️ Donnez d\'abord un indice !');return;}
 100  
 101    board[i].revealed = true;
 102    const c = board[i];
 103  
 104    if(c.team === 'assassin'){
 105      addLog(`💀 ${c.name} — ASSASSIN ! ${turn === 'blue' ? 'Rouge' : 'Bleu'} gagne !`);
 106      gameOver = true;
 107      showWin(turn === 'blue' ? 'red' : 'blue', true);
 108      updateUI();
 109      return;
 110    }
 111  
 112    if(c.team === 'blue'){
 113      blueLeft--;
 114      addLog(`🔵 ${c.name} — Correct pour Bleu !`);
 115      if(blueLeft === 0){gameOver = true;showWin('blue');updateUI();return;}
 116      if(turn !== 'blue'){guessesLeft = 0;}
 117    } else if(c.team === 'red'){
 118      redLeft--;
 119      addLog(`🔴 ${c.name} — Correct pour Rouge !`);
 120      if(redLeft === 0){gameOver = true;showWin('red');updateUI();return;}
 121      if(turn !== 'red'){guessesLeft = 0;}
 122    } else {
 123      addLog(`⚪ ${c.name} — Neutre. Fin du tour.`);
 124      guessesLeft = 0;
 125    }
 126  
 127    if(c.team === turn){
 128      guessesLeft--;
 129      if(guessesLeft <= 0){
 130        addLog(`↩️ Plus de tentatives. Au tour de ${turn === 'blue' ? 'Rouge' : 'Bleu'}.`);
 131        switchTurn();
 132      }
 133    } else {
 134      switchTurn();
 135    }
 136  
 137    updateUI();
 138  }
 139  
 140  function switchTurn(){
 141    turn = turn === 'blue' ? 'red' : 'blue';
 142    hintActive = false;
 143    guessesLeft = 0;
 144    document.getElementById('hintDisplay').textContent = '';
 145  }
 146  
 147  function passTurn(){
 148    if(gameOver) return;
 149    addLog(`⏭️ ${turn === 'blue' ? 'Bleu' : 'Rouge'} passe son tour.`);
 150    switchTurn();
 151    updateUI();
 152  }
 153  
 154  function giveHint(){
 155    if(gameOver) return;
 156    const word = document.getElementById('hintWord').value.trim();
 157    const num = parseInt(document.getElementById('hintNum').value) || 0;
 158    if(!word){addLog('⚠️ Entrez un mot comme indice !');return;}
 159  
 160    hintActive = true;
 161    guessesLeft = num + 1; // Codenames rule: guess = number + 1
 162    document.getElementById('hintDisplay').textContent = `🔎 "${word.toUpperCase()}" → ${num}`;
 163    document.getElementById('hintWord').value = '';
 164    addLog(`💡 ${turn === 'blue' ? 'Bleu' : 'Rouge'} : "${word}" pour ${num} (${guessesLeft} tentatives)`);
 165  }
 166  
 167  function toggleSpy(){
 168    spyMode = document.getElementById('spyToggle').checked;
 169    renderGrid();
 170  }
 171  
 172  function showWin(winner, assassin = false){
 173    const modal = document.getElementById('modal');
 174    const title = document.getElementById('modalTitle');
 175    const msg = document.getElementById('modalMsg');
 176    title.innerHTML = `<span class="winner-${winner}">${winner === 'blue' ? '🔵 Bleu' : '🔴 Rouge'} gagne !</span>`;
 177    msg.textContent = assassin
 178      ? `L'équipe adverse a révélé l'Assassin !`
 179      : `Toutes les cartes de l'équipe ${winner === 'blue' ? 'Bleu' : 'Rouge'} ont été trouvées !`;
 180    modal.classList.add('show');
 181  }
 182  
 183  // ── INIT ──
 184  function initBoard(){
 185    const cards = pickCards();
 186    const types = assignTeams();
 187    board = cards.map((c, i) => ({...c, team: types[i], revealed: false}));
 188    turn = 'blue';
 189    blueLeft = 9;
 190    redLeft = 8;
 191    spyMode = false;
 192    hintActive = false;
 193    guessesLeft = 0;
 194    gameOver = false;
 195    logs = [];
 196    document.getElementById('spyToggle').checked = false;
 197    document.getElementById('hintDisplay').textContent = '';
 198    addLog('🎮 Nouvelle partie ! L\'équipe Bleu commence.');
 199    updateUI();
 200  }
 201  
 202  function startGame(){
 203    document.getElementById('splash').classList.add('hidden');
 204    initBoard();
 205  }
 206  
 207  function newGame(){
 208    document.getElementById('modal').classList.remove('show');
 209    initBoard();
 210  }
 211  
 212  // Pre-render empty grid
 213  initBoard();
