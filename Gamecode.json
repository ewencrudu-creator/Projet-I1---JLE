Structure HTML & Styles CSS : 
Cette section contient la déclaration du document HTML, les imports de polices (Space Mono et Outfit via Google Fonts) et l’intégralité des styles CSS. Les variables CSS définies dans :root permettent de maintenir une cohérence visuelle (couleurs des équipes, surfaces, textes). Le design utilise un thème sombre avec des accents bleu et rouge.

<!DOCTYPE html>
   2  <html lang="fr">
   3  <head>
   4  <meta charset="UTF-8">
   5  <meta name="viewport" content="width=device-width, initial-scale=1.0">
   6  <title>CodeSource — Le Jeu des Noms de Code Tech</title>
   7  <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Outfit:wght@300;400;600;700;800;900&display=swap" rel="stylesheet">
   8  <style>
   9  *{margin:0;padding:0;box-sizing:border-box}
  10  :root{
  11    --bg:#0a0e17;--surface:#111827;--surface2:#1a2332;
  12    --blue:#3b82f6;--blue-dim:#1e3a5f;--blue-glow:rgba(59,130,246,.25);
  13    --red:#ef4444;--red-dim:#5f1e1e;--red-glow:rgba(239,68,68,.25);
  14    --neutral:#64748b;--neutral-dim:#2d3748;
  15    --assassin:#000;--assassin-border:#dc2626;
  16    --text:#e2e8f0;--text-dim:#94a3b8;--text-dark:#475569;
  17    --gold:#f59e0b;--green:#10b981;
  18    --font-mono:'Space Mono',monospace;--font-sans:'Outfit',sans-serif;
  19  }
  20  html,body{height:100%;font-family:var(--font-sans);background:var(--bg);color:var(--text);overflow-x:hidden}
  21  body{display:flex;flex-direction:column;min-height:100vh}
  22  
  23  /* ── SPLASH SCREEN ── */
  24  .splash{position:fixed;inset:0;z-index:1000;background:var(--bg);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:28px;transition:opacity .6s,visibility .6s}
  25  .splash.hidden{opacity:0;visibility:hidden;pointer-events:none}
  26  .splash h1{font-size:clamp(2.2rem,6vw,4.5rem);font-weight:900;letter-spacing:-2px;background:linear-gradient(135deg,var(--blue),#a78bfa,var(--red));-webkit-background-clip:text;-webkit-text-fill-color:transparent}
  27  .splash p{color:var(--text-dim);font-size:1.05rem;max-width:520px;text-align:center;line-height:1.6}
  28  .splash .rules{text-align:left;background:var(--surface);border:1px solid rgba(255,255,255,.06);border-radius:14px;padding:22px 28px;max-width:580px;font-size:.92rem;line-height:1.7;color:var(--text-dim)}
  29  .splash .rules strong{color:var(--text)}
  30  .splash .rules .color-dot{display:inline-block;width:11px;height:11px;border-radius:50%;margin-right:4px;vertical-align:-1px}
  31  .splash .rules .color-dot.b{background:var(--blue)}.splash .rules .color-dot.r{background:var(--red)}.splash .rules .color-dot.n{background:var(--neutral)}.splash .rules .color-dot.a{background:var(--assassin);border:2px solid var(--assassin-border)}
  32  .btn{font-family:var(--font-sans);font-weight:700;font-size:1rem;border:none;border-radius:10px;padding:14px 36px;cursor:pointer;transition:all .2s;letter-spacing:.3px}
  33  .btn-start{background:linear-gradient(135deg,var(--blue),#6366f1);color:#fff;box-shadow:0 4px 24px rgba(99,102,241,.35)}
  34  .btn-start:hover{transform:translateY(-2px);box-shadow:0 6px 32px rgba(99,102,241,.5)}
  35  .btn-sm{padding:8px 18px;font-size:.82rem;border-radius:8px}
  36  .btn-outline{background:transparent;border:1.5px solid rgba(255,255,255,.15);color:var(--text-dim)}
  37  .btn-outline:hover{border-color:var(--blue);color:var(--blue)}
  38  
  39  /* ── TOP BAR ── */
  40  .topbar{display:flex;align-items:center;justify-content:space-between;padding:12px 20px;background:var(--surface);border-bottom:1px solid rgba(255,255,255,.05)}
  41  .topbar .logo{font-family:var(--font-mono);font-weight:700;font-size:1.1rem;letter-spacing:-1px}
  42  .topbar .logo span{color:var(--blue)}
  43  .score-area{display:flex;gap:16px;align-items:center}
  44  .score-pill{display:flex;align-items:center;gap:6px;padding:5px 14px;border-radius:20px;font-weight:700;font-size:.9rem}
  45  .score-pill.blue{background:var(--blue-dim);color:var(--blue)}.score-pill.red{background:var(--red-dim);color:var(--red)}
  46  .turn-badge{padding:5px 14px;border-radius:20px;font-weight:600;font-size:.82rem;animation:pulse 2s infinite}
  47  .turn-badge.blue{background:var(--blue-dim);color:var(--blue);border:1px solid var(--blue)}.turn-badge.red{background:var(--red-dim);color:var(--red);border:1px solid var(--red)}
  48  @keyframes pulse{0%,100%{opacity:1}50%{opacity:.65}}
  49  
  50  /* ── SPYMASTER BAR ── */
  51  .spy-bar{display:flex;align-items:center;justify-content:center;gap:12px;padding:10px 20px;background:rgba(245,158,11,.06);border-bottom:1px solid rgba(245,158,11,.12)}
  52  .spy-bar label{font-size:.85rem;color:var(--gold);font-weight:600}
  53  .toggle{position:relative;width:44px;height:24px;cursor:pointer}
  54  .toggle input{display:none}
  55  .toggle .slider{position:absolute;inset:0;background:var(--neutral-dim);border-radius:12px;transition:.3s}
  56  .toggle .slider::before{content:'';position:absolute;width:18px;height:18px;left:3px;top:3px;background:var(--text-dim);border-radius:50%;transition:.3s}
  57  .toggle input:checked+.slider{background:var(--gold)}.toggle input:checked+.slider::before{transform:translateX(20px);background:#fff}
  58  
  59  /* ── HINT AREA ── */
  60  .hint-area{display:flex;align-items:center;justify-content:center;gap:12px;padding:10px 20px;background:var(--surface2);border-bottom:1px solid rgba(255,255,255,.04)}
  61  .hint-area input{font-family:var(--font-mono);background:var(--surface);border:1.5px solid rgba(255,255,255,.1);color:var(--text);padding:8px 14px;border-radius:8px;font-size:.9rem;width:180px;text-align:center}
  62  .hint-area input::placeholder{color:var(--text-dark)}
  63  .hint-area input[type=number]{width:60px}
  64  .hint-display{font-family:var(--font-mono);font-size:1.1rem;font-weight:700;color:var(--gold);letter-spacing:1px}
  65  
  66  /* ── GRID ── */
  67  .grid-wrap{flex:1;display:flex;align-items:center;justify-content:center;padding:16px}
  68  .grid{display:grid;grid-template-columns:repeat(5,1fr);gap:10px;max-width:960px;width:100%}
  69  .card{position:relative;aspect-ratio:1.6;border-radius:12px;cursor:pointer;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:8px 6px;border:2px solid rgba(255,255,255,.08);background:var(--surface2);transition:all .25s;overflow:hidden;user-select:none}
  70  .card:hover:not(.revealed){transform:translateY(-3px);border-color:rgba(255,255,255,.18);box-shadow:0 8px 24px rgba(0,0,0,.3)}
  71  .card .card-name{font-weight:700;font-size:clamp(.6rem,1.4vw,.88rem);line-height:1.2;z-index:1;padding:0 2px;word-break:break-word}
  72  .card .card-family{font-size:.6rem;color:var(--text-dark);margin-top:4px;font-weight:600;text-transform:uppercase;letter-spacing:.5px;z-index:1}
  73  .card .card-period{font-size:.55rem;color:var(--text-dark);margin-top:2px;z-index:1;opacity:.7}
  74  
  75  /* Spymaster colors */
  76  .card.spy-blue{border-color:var(--blue);box-shadow:inset 0 0 20px var(--blue-glow)}
  77  .card.spy-blue::after{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:var(--blue)}
  78  .card.spy-red{border-color:var(--red);box-shadow:inset 0 0 20px var(--red-glow)}
  79  .card.spy-red::after{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:var(--red)}
  80  .card.spy-neutral{border-color:var(--neutral);opacity:.7}
  81  .card.spy-assassin{border-color:var(--assassin-border);background:repeating-linear-gradient(45deg,var(--surface2),var(--surface2) 4px,rgba(220,38,38,.06) 4px,rgba(220,38,38,.06) 8px)}
  82  
  83  /* Revealed */
  84  .card.revealed{cursor:default;transform:none !important}
  85  .card.revealed.team-blue{background:linear-gradient(135deg,var(--blue-dim),rgba(59,130,246,.15));border-color:var(--blue)}
  86  .card.revealed.team-blue .card-name{color:var(--blue)}
  87  .card.revealed.team-red{background:linear-gradient(135deg,var(--red-dim),rgba(239,68,68,.15));border-color:var(--red)}
  88  .card.revealed.team-red .card-name{color:var(--red)}
  89  .card.revealed.team-neutral{background:var(--neutral-dim);border-color:var(--neutral);opacity:.5}
  90  .card.revealed.team-neutral .card-name{color:var(--neutral)}
  91  .card.revealed.team-assassin{background:linear-gradient(135deg,#1a0000,#2d0000);border-color:var(--assassin-border)}
  92  .card.revealed.team-assassin .card-name{color:var(--red);text-decoration:line-through}
  93  
  94  .card .reveal-icon{position:absolute;top:6px;right:8px;font-size:.8rem;opacity:0;transition:opacity .3s}
  95  .card.revealed .reveal-icon{opacity:1}
  96  
  97  /* ── INFO TOOLTIP ── */
  98  .card .tooltip{position:absolute;bottom:100%;left:50%;transform:translateX(-50%);background:#1e293b;border:1px solid rgba(255,255,255,.1);border-radius:10px;padding:10px 14px;width:220px;font-size:.75rem;line-height:1.5;color:var(--text-dim);pointer-events:none;opacity:0;transition:opacity .2s;z-index:50;box-shadow:0 8px 24px rgba(0,0,0,.4)}
  99  .card:hover .tooltip{opacity:1}
 100  .tooltip strong{color:var(--text);display:block;margin-bottom:3px}
 101  
 102  /* ── MODAL ── */
 103  .modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.7);z-index:500;display:flex;align-items:center;justify-content:center;opacity:0;visibility:hidden;transition:all .3s}
 104  .modal-overlay.show{opacity:1;visibility:visible}
 105  .modal{background:var(--surface);border:1px solid rgba(255,255,255,.08);border-radius:18px;padding:36px;text-align:center;max-width:420px;width:90%}
 106  .modal h2{font-size:1.8rem;margin-bottom:8px}
 107  .modal p{color:var(--text-dim);margin-bottom:20px}
 108  .modal .winner-blue{color:var(--blue)}.modal .winner-red{color:var(--red)}
 109  
 110  /* ── FOOTER LOG ── */
 111  .log-bar{padding:8px 20px;background:var(--surface);border-top:1px solid rgba(255,255,255,.05);font-size:.78rem;color:var(--text-dark);font-family:var(--font-mono);overflow-x:auto;white-space:nowrap;display:flex;gap:16px}
 112  .log-entry{opacity:.7}.log-entry:last-child{opacity:1;color:var(--text-dim)}
 113  
 114  /* ── RESPONSIVE ── */
 115  @media(max-width:700px){
 116    .grid{grid-template-columns:repeat(5,1fr);gap:6px;max-width:100%}
 117    .card{padding:5px 3px;border-radius:8px;aspect-ratio:1.3}
 118    .card .card-name{font-size:.55rem}
 119    .card .card-family,.card .card-period{display:none}
 120    .card .tooltip{display:none}
 121    .hint-area{flex-wrap:wrap}
 122  }
 123  </style>


Structure HTML du jeu : 
Le corps HTML contient tous les éléments visuels du jeu : l’écran d’accueil (splash) avec les règles, la barre supérieure avec scores et boutons, la barre du Maître-Espion, la zone de saisie des indices, la grille de jeu et la modale de fin de partie.

1  
   2  <body>
   3  
   4  <!-- SPLASH -->
   5  <div class="splash" id="splash">
   6    <h1>CodeSource</h1>
   7    <p>Un jeu de type <strong>Codenames</strong> pour apprendre l'histoire de l'open source, du numérique et de l'IA</p>
   8    <div class="rules">
   9      <strong>Règles du jeu :</strong><br><br>
  10      Deux équipes s'affrontent : <span class="color-dot b"></span><strong>Bleu</strong> et <span class="color-dot r"></span><strong>Rouge</strong>.<br><br>
  11      Le <strong>Maître-Espion</strong> de chaque équipe voit la grille secrète et donne un <strong>indice</strong> (un mot + un chiffre) pour faire deviner plusieurs cartes à son équipe.<br><br>
  12      <span class="color-dot b"></span> <strong>9 cartes bleues</strong> — <span class="color-dot r"></span> <strong>8 cartes rouges</strong> — <span class="color-dot n"></span> 7 cartes neutres — <span class="color-dot a"></span> 1 carte assassin<br><br>
  13      Si une équipe révèle la carte <strong>Assassin</strong>, elle perd immédiatement ! Chaque carte représente un concept clé de l'histoire du numérique et de l'open source — survolez-les pour apprendre.
  14    </div>
  15    <button class="btn btn-start" onclick="startGame()">Commencer la partie</button>
  16  </div>
  17  
  18  <!-- GAME -->
  19  <div class="topbar">
  20    <div class="logo">&lt;<span>Code</span>Source/&gt;</div>
  21    <div class="score-area">
  22      <div class="score-pill blue" id="scoreBlue">Bleu: 9</div>
  23      <div class="turn-badge blue" id="turnBadge">Tour : Bleu</div>
  24      <div class="score-pill red" id="scoreRed">Rouge: 8</div>
  25    </div>
  26    <div style="display:flex;gap:8px">
  27      <button class="btn btn-sm btn-outline" onclick="passTurn()">Passer le tour</button>
  28      <button class="btn btn-sm btn-outline" onclick="newGame()">Nouvelle partie</button>
  29    </div>
  30  </div>
  31  
  32  <div class="spy-bar">
  33    <label>Mode Maître-Espion</label>
  34    <label class="toggle"><input type="checkbox" id="spyToggle" onchange="toggleSpy()"><span class="slider"></span></label>
  35  </div>
  36  
  37  <div class="hint-area" id="hintArea">
  38    <input type="text" id="hintWord" placeholder="Indice…">
  39    <input type="number" id="hintNum" min="0" max="9" value="2" placeholder="#">
  40    <button class="btn btn-sm btn-start" onclick="giveHint()">Donner l'indice</button>
  41    <div class="hint-display" id="hintDisplay"></div>
  42  </div>
  43  
  44  <div class="grid-wrap">
  45    <div class="grid" id="grid"></div>
  46  </div>
  47  
  48  <div class="log-bar" id="logBar">
  49    <span class="log-entry">Partie prête…</span>
  50  </div>
  51  
  52  <!-- WIN MODAL -->
  53  <div class="modal-overlay" id="modal">
  54    <div class="modal">
  55      <h2 id="modalTitle">Victoire !</h2>
  56      <p id="modalMsg"></p>
  57      <button class="btn btn-start" onclick="newGame();document.getElementById('modal').classList.remove('show')">Rejouer</button>
  58    </div>
  59  </div>
